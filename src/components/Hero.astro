---
// Hero.astro
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-24 lg:pt-20 lg:pb-32 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
  <div class="lg:col-span-6 space-y-8">
    <div class="flex flex-wrap gap-2">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-emerald/30 bg-brand-emerald/5 text-brand-emerald text-xs font-bold tracking-widest uppercase">
        <span class="h-2 w-2 bg-brand-emerald rounded-full" />
        DIRECT PAYMENT GATEWAY
      </div>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-neonMint/30 bg-brand-neonMint/5 text-brand-neonMint text-xs font-bold tracking-widest uppercase">
        OPEN SOURCE
      </div>
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-[54px] font-black uppercase tracking-tight text-white leading-[1.05]">
      The <span class="text-brand-emerald">AI-Native</span> storefront checkout engine for PH merchants
    </h1>

    <p class="text-lg text-brand-mint leading-relaxed max-w-xl">
      Orchestrate your checkouts conversationally via AI agents. Connect your own PayMongo account to process payments directly with 0% platform transaction fees.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 pt-2">
      <a href="https://github.com/jedmamosto/open-wizpay" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto">
        <button class="w-full bg-brand-emerald hover:bg-brand-emeraldHover text-brand-dark text-sm font-bold uppercase tracking-wider py-4 px-8 rounded-lg transition-all duration-300 transform hover:scale-[1.02] shadow-[0_4px_20px_rgba(204,241,90,0.2)]">
          Deploy WizPay →
        </button>
      </a>
      <a href="#ai-onboarding" class="w-full sm:w-auto">
        <button class="w-full border border-[#1d3a2c] text-white hover:bg-brand-borderGreen hover:text-white text-sm font-bold uppercase tracking-wider py-4 px-8 rounded-lg">
          AI Onboarding
        </button>
      </a>
    </div>
  </div>

  <slot name="sandbox" />
</section>
