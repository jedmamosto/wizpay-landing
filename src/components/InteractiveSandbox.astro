---
// InteractiveSandbox.astro
// Zero framework overhead, vanilla JS interactivity
---

<div id="sandbox-demo" class="lg:col-span-6 w-full max-w-xl mx-auto">
  <div class="border border-[#1d3a2c] rounded-xl bg-[#062517]/70 backdrop-blur-md shadow-lg overflow-hidden">
    
    <!-- Header -->
    <div class="bg-[#022113] px-3 py-3 sm:px-4 flex items-center justify-between border-b border-[#112f21]">
      <div class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-red-500/30" />
        <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/30" />
        <span class="w-2.5 h-2.5 rounded-full bg-green-500/30" />
        <span class="text-[11px] font-mono text-[#a6d0b5]/70 ml-2 tracking-widest uppercase hidden sm:inline">Interactive Sandbox</span>
      </div>
      
      <!-- Tab Controls -->
      <div role="tablist" class="flex bg-[#00180c] p-0.5 rounded-lg border border-[#112f21]" id="sandbox-tabs">
        <button role="tab" data-tab="designer" class="px-2.5 py-1.5 sm:px-3 sm:py-2 rounded text-[9px] sm:text-[10px] font-bold uppercase tracking-wider transition-all focus:outline-none bg-brand-emerald text-brand-emeraldText">
          Visual Designer
        </button>
        <button role="tab" data-tab="checkout" class="px-2.5 py-1.5 sm:px-3 sm:py-2 rounded text-[9px] sm:text-[10px] font-bold uppercase tracking-wider transition-all focus:outline-none text-[#c5c9b1] hover:text-white">
          Checkout View
        </button>
        <button role="tab" data-tab="dashboard" class="px-2.5 py-1.5 sm:px-3 sm:py-2 rounded text-[9px] sm:text-[10px] font-bold uppercase tracking-wider transition-all focus:outline-none text-[#c5c9b1] hover:text-white">
          Merchant Panel
        </button>
      </div>
    </div>

    <!-- Main Container -->
    <div class="p-6 min-h-[460px] flex flex-col justify-between" id="sandbox-container">
      
      <!-- ================= DESIGNER PANEL ================= -->
      <div id="panel-designer" class="space-y-6 tab-panel">
        <div class="border-b border-[#112f21] pb-4">
          <h4 class="text-xs font-mono uppercase tracking-widest text-[#a6d0b5]">Interactive Form Builder</h4>
          <h3 class="text-lg font-bold text-white mt-1">Design Your Checkout Button</h3>
        </div>
        <div class="space-y-4">
          <div class="space-y-2">
            <label for="designer-title" class="text-[10px] font-mono uppercase tracking-wider text-[#a6d0b5] block">Product Name</label>
            <input id="designer-title" type="text" value="Batangas Coffee Roast" class="w-full bg-[#001208] border border-[#112f21] rounded-lg p-3 text-sm text-white focus:outline-none focus:border-[#ccf15a] transition-all" />
          </div>
          <div class="space-y-2">
            <label for="designer-price" class="text-[10px] font-mono uppercase tracking-wider text-[#a6d0b5] block">Price (PHP)</label>
            <input id="designer-price" type="number" value="750" class="w-full bg-[#001208] border border-[#112f21] rounded-lg p-3 text-sm text-white focus:outline-none focus:border-[#ccf15a] transition-all" />
          </div>
          <div class="space-y-2">
            <span class="text-[10px] font-mono uppercase tracking-wider text-[#a6d0b5] block">Checkout Highlight Color</span>
            <div class="flex gap-3 pt-1" id="color-selectors">
              <button data-color="emerald" class="w-8 h-8 rounded-full border-2 border-white scale-110 bg-[#ccf15a]" title="emerald"></button>
              <button data-color="indigo" class="w-8 h-8 rounded-full border-2 border-transparent hover:scale-105 bg-[#818cf8]" title="indigo"></button>
              <button data-color="amber" class="w-8 h-8 rounded-full border-2 border-transparent hover:scale-105 bg-[#fbbf24]" title="amber"></button>
              <button data-color="sky" class="w-8 h-8 rounded-full border-2 border-transparent hover:scale-105 bg-[#38bdf8]" title="sky"></button>
            </div>
          </div>
        </div>
        <button id="preview-checkout-btn" class="w-full font-bold text-xs uppercase tracking-wider py-4 rounded-lg bg-brand-emerald text-brand-emeraldText transition-all transform hover:opacity-90 mt-2">
          Preview Checkout Page
        </button>
      </div>

      <!-- ================= CHECKOUT PANEL ================= -->
      <div id="panel-checkout" class="space-y-6 tab-panel hidden">
        <div class="border-b border-[#112f21] pb-4 flex justify-between items-center">
          <div>
            <h4 class="text-xs font-mono uppercase tracking-widest text-[#a6d0b5]">Your Store Checkout</h4>
            <h3 id="checkout-title" class="text-lg font-bold text-white mt-1">Batangas Coffee Roast</h3>
          </div>
          <div class="text-right">
            <span class="text-[10px] font-mono uppercase text-[#c8ebd5] block opacity-70">Amount Due</span>
            <span id="checkout-price-display" class="text-xl font-black text-white">₱750.00</span>
          </div>
        </div>

        <!-- Checkout Idle State -->
        <div id="checkout-idle" class="space-y-4">
          <div class="space-y-3">
            <span class="text-xs font-mono uppercase tracking-wider text-[#a6d0b5] block">Select Payment Method</span>
            <div class="grid grid-cols-1 gap-2.5" id="payment-methods">
              <button data-method="gcash" class="p-4 rounded-lg border text-left flex items-center justify-between transition-all border-brand-emerald bg-brand-emerald/5 text-white">
                <div class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full bg-blue-600 flex items-center justify-center text-[9px] font-black text-white">G</div>
                  <div>
                    <span class="font-bold text-sm block">GCash Account</span>
                    <span class="text-[11px] text-[#a6d0b5]">Standard mobile authorization</span>
                  </div>
                </div>
                <div class="w-4 h-4 rounded-full border border-brand-emerald flex items-center justify-center">
                  <div class="w-2.5 h-2.5 rounded-full bg-brand-emerald" id="dot-gcash"></div>
                </div>
              </button>

              <button data-method="maya" class="p-4 rounded-lg border text-left flex items-center justify-between transition-all border-[#112f21] bg-[#001208] text-[#c5c9b1] hover:border-brand-emerald/30">
                <div class="flex items-center gap-3">
                  <div class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center text-[9px] font-black text-white">M</div>
                  <div>
                    <span class="font-bold text-sm block">Maya Wallet</span>
                    <span class="text-[11px] text-[#a6d0b5]">Direct scan or OTP confirmation</span>
                  </div>
                </div>
                <div class="w-4 h-4 rounded-full border border-[#112f21] flex items-center justify-center">
                  <div class="w-2.5 h-2.5 rounded-full bg-transparent" id="dot-maya"></div>
                </div>
              </button>

              <button data-method="card" class="p-4 rounded-lg border text-left flex items-center justify-between transition-all border-[#112f21] bg-[#001208] text-[#c5c9b1] hover:border-brand-emerald/30">
                <div class="flex items-center gap-3">
                  <span class="text-white text-base">💳</span>
                  <div class="ml-1">
                    <span class="font-bold text-sm block">Credit/Debit Card</span>
                    <span class="text-[11px] text-[#a6d0b5]">Visa, Mastercard, & JCB direct</span>
                  </div>
                </div>
                <div class="w-4 h-4 rounded-full border border-[#112f21] flex items-center justify-center">
                  <div class="w-2.5 h-2.5 rounded-full bg-transparent" id="dot-card"></div>
                </div>
              </button>
            </div>
          </div>
          <button id="pay-button" class="w-full font-bold text-sm uppercase tracking-wider py-5 rounded-lg bg-brand-emerald text-brand-emeraldText transition-all">
            Pay ₱750.00
          </button>
        </div>

        <!-- Checkout Processing State -->
        <div id="checkout-processing" class="space-y-6 py-8 flex flex-col items-center justify-center hidden">
          <div id="spinner" class="w-16 h-16 rounded-full border-4 border-[#112f21] border-t-brand-emerald animate-spin"></div>
          <div class="w-full max-w-sm space-y-2.5">
            <div class="flex justify-between text-xs font-mono">
              <span class="text-[#a6d0b5]">Secure Settlement Route</span>
              <span id="progress-percent" class="text-brand-emerald">15%</span>
            </div>
            <div class="w-full bg-[#112f21] h-2 rounded-full overflow-hidden">
              <div id="progress-bar" class="h-full bg-brand-emerald transition-all duration-300" style="width: 15%"></div>
            </div>
          </div>
          <div class="w-full bg-[#001208] border border-[#112f21] p-3 rounded-lg font-mono text-[10px] space-y-1 max-h-[140px] overflow-y-auto" id="checkout-logs"></div>
        </div>

        <!-- Checkout Success State -->
        <div id="checkout-success" class="text-center py-8 space-y-6 hidden">
          <div class="inline-flex h-16 w-16 items-center justify-center rounded-full border border-brand-emerald/40 bg-brand-emerald/10 text-brand-emerald mx-auto text-3xl font-black">✓</div>
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-white uppercase tracking-wider">Checkout Confirmed</h3>
            <p class="text-sm text-[#a6d0b5] max-w-sm mx-auto">Payment has successfully routed. In a live environment, these funds deposit directly to your personal bank account.</p>
          </div>
          <div class="bg-[#022113] border border-[#6dfe9c]/20 p-4 rounded-lg max-w-sm mx-auto text-left">
            <p class="text-xs font-mono flex items-center gap-1.5 font-bold uppercase tracking-wider mb-1 text-brand-emerald">
              🔒 Direct Settlement Log
            </p>
            <p class="text-[11px] text-[#a6d0b5] leading-relaxed">Your customer was charged directly. WizPay took ₱0.00 platform cuts. Settles to your merchant balance in 1 business day.</p>
          </div>
          <div class="flex gap-3 justify-center pt-2">
            <button id="test-again-btn" class="px-4 py-2 border border-[#1d3a2c] hover:border-brand-emerald text-white hover:bg-brand-emerald/5 text-xs font-bold uppercase tracking-wider rounded transition-all">Test Again</button>
            <button id="go-dashboard-btn" class="px-4 py-2 text-xs font-bold uppercase tracking-wider rounded transition-all bg-brand-emerald text-brand-emeraldText">Check Merchant Panel</button>
          </div>
        </div>
      </div>

      <!-- ================= DASHBOARD PANEL ================= -->
      <div id="panel-dashboard" class="space-y-5 tab-panel hidden">
        <div class="flex items-center justify-between border-b border-[#112f21] pb-3">
          <div class="flex items-center gap-2">
            <span class="text-brand-emerald text-sm animate-spin">⚙</span>
            <span class="text-sm font-bold text-white uppercase tracking-wider">WizPay Portal (Demo)</span>
          </div>
          <span class="text-[10px] font-mono bg-[#022113] border border-brand-emerald/40 px-2 py-0.5 rounded text-brand-emerald">DIRECT SETTLEMENT ACTIVE</span>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="p-3 bg-[#022113] border border-[#112f21] rounded-lg">
            <span class="text-[9px] font-mono uppercase tracking-widest text-[#a6d0b5] block">Direct Net Settled</span>
            <span class="text-lg font-black text-white block mt-0.5" id="dashboard-net-settled">₱2,400.00</span>
          </div>
          <div class="p-3 bg-[#022113] border border-[#112f21] rounded-lg">
            <span class="text-[9px] font-mono uppercase tracking-widest text-[#a6d0b5] block">Platform Fees Taken</span>
            <span class="text-lg font-black text-brand-emerald block mt-0.5">₱0.00</span>
          </div>
        </div>
        <div class="space-y-3">
          <div class="flex items-center justify-between p-3 bg-[#001208] border border-[#112f21] rounded-lg text-xs">
            <div class="flex items-center gap-2"><div class="w-2.5 h-2.5 rounded-full bg-[#6dfe9c]"></div><span class="font-bold text-white">GCash direct gateway</span></div>
            <span class="font-mono text-[#a6d0b5]">Connected (PayMongo API)</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-[#001208] border border-[#112f21] rounded-lg text-xs">
            <div class="flex items-center gap-2"><div class="w-2.5 h-2.5 rounded-full bg-[#6dfe9c]"></div><span class="font-bold text-white">Maya direct gateway</span></div>
            <span class="font-mono text-[#a6d0b5]">Connected (PayMongo API)</span>
          </div>
        </div>
        <div class="space-y-2">
          <span class="text-[10px] font-mono uppercase tracking-wider text-[#a6d0b5] block">Simulation Log History</span>
          <div class="space-y-1.5 max-h-[110px] overflow-y-auto font-mono text-[10px]" id="dashboard-txs">
            <div class="flex items-center justify-between p-2 bg-[#022113]/30 border border-[#112f21]/40 rounded text-[#a6d0b5]">
              <span class="flex items-center gap-1.5">✓ <span class="dashboard-custom-tx">₱750.00 - GCash</span></span>
              <span class="text-brand-emerald font-bold">100% KEPT</span>
            </div>
            <div class="flex items-center justify-between p-2 bg-[#022113]/30 border border-[#112f21]/40 rounded text-[#a6d0b5]">
              <span class="flex items-center gap-1.5">✓ ₱1,200.00 - Visa Card</span>
              <span class="text-[#6dfe9c] font-bold">100% KEPT</span>
            </div>
            <div class="flex items-center justify-between p-2 bg-[#022113]/30 border border-[#112f21]/40 rounded text-[#a6d0b5]">
              <span class="flex items-center gap-1.5">✓ ₱450.00 - Maya</span>
              <span class="text-[#6dfe9c] font-bold">100% KEPT</span>
            </div>
          </div>
        </div>
        <div class="pt-2">
          <a href="http://localhost:3000/admin" class="w-full">
            <button class="w-full bg-[#022113] hover:bg-white/5 border border-brand-emerald/40 text-white font-bold text-xs uppercase tracking-wider py-4 rounded-lg">Configure PayMongo Account</button>
          </a>
        </div>
      </div>

      <!-- Banner Footer -->
      <div class="mt-4 pt-3 border-t border-[#112f21] text-center">
        <span class="text-[10px] font-mono text-[#a6d0b5] uppercase tracking-widest block font-medium">Use designer to customize text, prices, and colors.</span>
      </div>
    </div>
  </div>
</div>

<script>
  // UI logic compiled to zero-dependency Vanilla JS
  const tabs = document.querySelectorAll('#sandbox-tabs button');
  const panels = document.querySelectorAll('.tab-panel');
  const colorButtons = document.querySelectorAll('#color-selectors button');
  const previewCheckoutBtn = document.getElementById('preview-checkout-btn');
  
  // Customizer state
  let currentProduct = 'Batangas Coffee Roast';
  let currentPrice = 750;
  let currentColor = 'emerald';
  let paymentMethod = 'gcash';
  let totalSettled = 2400;

  const colorMap = {
    emerald: { primary: '#ccf15a', primaryText: '#161e00', border: 'border-[#ccf15a]', bgLight: 'bg-[#ccf15a]/5', bgDot: 'bg-[#ccf15a]', textAccent: 'text-[#ccf15a]' },
    indigo: { primary: '#818cf8', primaryText: '#0f172a', border: 'border-[#818cf8]', bgLight: 'bg-[#818cf8]/5', bgDot: 'bg-[#818cf8]', textAccent: 'text-[#818cf8]' },
    amber: { primary: '#fbbf24', primaryText: '#451a03', border: 'border-[#fbbf24]', bgLight: 'bg-[#fbbf24]/5', bgDot: 'bg-[#fbbf24]', textAccent: 'text-[#fbbf24]' },
    sky: { primary: '#38bdf8', primaryText: '#0c4a6e', border: 'border-[#38bdf8]', bgLight: 'bg-[#38bdf8]/5', bgDot: 'bg-[#38bdf8]', textAccent: 'text-[#38bdf8]' }
  };

  function switchTab(targetTab) {
    tabs.forEach(btn => {
      if (btn.getAttribute('data-tab') === targetTab) {
        btn.classList.add('bg-brand-emerald', 'text-brand-emeraldText');
        btn.classList.remove('text-[#c5c9b1]', 'hover:text-white');
      } else {
        btn.classList.remove('bg-brand-emerald', 'text-brand-emeraldText');
        btn.classList.add('text-[#c5c9b1]', 'hover:text-white');
      }
    });

    panels.forEach(panel => {
      if (panel.id === `panel-${targetTab}`) {
        panel.classList.remove('hidden');
      } else {
        panel.classList.add('hidden');
      }
    });
  }

  // Bind tabs
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      switchTab(btn.getAttribute('data-tab'));
    });
  });

  // Color changing
  colorButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      colorButtons.forEach(b => b.classList.remove('border-white', 'scale-110'));
      btn.classList.add('border-white', 'scale-110');
      currentColor = btn.getAttribute('data-color');
      applyColorScheme();
    });
  });

  // Apply colors to dynamic areas
  function applyColorScheme() {
    const scheme = colorMap[currentColor];
    const payBtn = document.getElementById('pay-button');
    const previewBtn = document.getElementById('preview-checkout-btn');
    
    if (payBtn) {
      payBtn.style.backgroundColor = scheme.primary;
      payBtn.style.color = scheme.primaryText;
    }
    if (previewBtn) {
      previewBtn.style.backgroundColor = scheme.primary;
      previewBtn.style.color = scheme.primaryText;
    }
    // Update active payment method selection styling
    updatePaymentMethodSelection();
  }

  // Input sync
  const titleInput = document.getElementById('designer-title') as HTMLInputElement;
  const priceInput = document.getElementById('designer-price') as HTMLInputElement;
  
  if (titleInput) titleInput.addEventListener('input', (e) => {
    currentProduct = (e.target as HTMLInputElement).value || 'Sample Checkout';
    document.getElementById('checkout-title').textContent = currentProduct;
  });

  if (priceInput) priceInput.addEventListener('input', (e) => {
    currentPrice = Number((e.target as HTMLInputElement).value) || 0;
    const formatted = `₱${currentPrice.toLocaleString(undefined, { minimumFractionDigits: 2 })}`;
    document.getElementById('checkout-price-display').textContent = formatted;
    document.getElementById('pay-button').textContent = `Pay ${formatted}`;
  });

  if (previewCheckoutBtn) {
    previewCheckoutBtn.addEventListener('click', () => {
      switchTab('checkout');
    });
  }

  // Payment method radio choice
  const pButtons = document.querySelectorAll('#payment-methods button');
  pButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      paymentMethod = btn.getAttribute('data-method');
      updatePaymentMethodSelection();
    });
  });

  function updatePaymentMethodSelection() {
    const scheme = colorMap[currentColor];
    pButtons.forEach(btn => {
      const method = btn.getAttribute('data-method');
      const dot = document.getElementById(`dot-${method}`);
      if (method === paymentMethod) {
        btn.className = `p-4 rounded-lg border text-left flex items-center justify-between transition-all ${scheme.border} ${scheme.bgLight} text-white`;
        if (dot) {
          dot.className = `w-2.5 h-2.5 rounded-full ${scheme.bgDot}`;
        }
      } else {
        btn.className = `p-4 rounded-lg border text-left flex items-center justify-between transition-all border-[#112f21] bg-[#001208] text-[#c5c9b1] hover:border-brand-emerald/30`;
        if (dot) {
          dot.className = `w-2.5 h-2.5 rounded-full bg-transparent`;
        }
      }
    });
  }

  // Simulated payment transaction flow
  const payBtn = document.getElementById('pay-button');
  const checkoutIdle = document.getElementById('checkout-idle');
  const checkoutProcessing = document.getElementById('checkout-processing');
  const checkoutSuccess = document.getElementById('checkout-success');
  const checkoutLogs = document.getElementById('checkout-logs');
  const progressPercent = document.getElementById('progress-percent');
  const progressBar = document.getElementById('progress-bar');
  const testAgainBtn = document.getElementById('test-again-btn');
  const goDashboardBtn = document.getElementById('go-dashboard-btn');

  function addLog(text) {
    const logItem = document.createElement('div');
    logItem.className = 'flex gap-2';
    logItem.innerHTML = `<span style="color: ${colorMap[currentColor].primary}">&gt;</span><span class="text-[#a6d0b5]">${text}</span>`;
    checkoutLogs.appendChild(logItem);
    checkoutLogs.scrollTop = checkoutLogs.scrollHeight;
  }

  if (payBtn) payBtn.addEventListener('click', () => {
    checkoutIdle.classList.add('hidden');
    checkoutProcessing.classList.remove('hidden');
    checkoutLogs.innerHTML = '';
    
    // Step 0
    addLog('[INIT] Customer initiated direct wallet checkout...');
    updateProgress(15);

    // Step 1
    setTimeout(() => {
      addLog('[ROUTING] Accessing direct merchant PayMongo credentials...');
      updateProgress(35);
    }, 600);

    // Step 2
    setTimeout(() => {
      addLog(`[GATEWAY] Redirecting customer to ${paymentMethod.toUpperCase()} auth gateway...`);
      updateProgress(65);
    }, 1300);

    // Step 3
    setTimeout(() => {
      addLog('[CALLBACK] Settlement webhook verified. Order completed.');
      updateProgress(85);
    }, 2200);

    // Step 4 (Success)
    setTimeout(() => {
      addLog('[SUCCESS] Funds settled directly to merchant balance. Overlay closing.');
      updateProgress(100);
      
      setTimeout(() => {
        checkoutProcessing.classList.add('hidden');
        checkoutSuccess.classList.remove('hidden');
        
        // Add to dashboard metrics
        totalSettled += currentPrice;
        document.getElementById('dashboard-net-settled').textContent = `₱${totalSettled.toLocaleString(undefined, { minimumFractionDigits: 2 })}`;
        
        // Add transaction to logs feed
        const dashboardTxs = document.getElementById('dashboard-txs');
        const customTx = document.createElement('div');
        customTx.className = 'flex items-center justify-between p-2 bg-[#022113]/30 border border-[#112f21]/40 rounded text-[#a6d0b5]';
        customTx.innerHTML = `<span class="flex items-center gap-1.5">✓ ₱${currentPrice.toFixed(2)} - ${paymentMethod.toUpperCase()}</span><span class="text-brand-emerald font-bold">100% KEPT</span>`;
        dashboardTxs.insertBefore(customTx, dashboardTxs.firstChild);
      }, 500);

    }, 2800);
  });

  function updateProgress(value) {
    progressPercent.textContent = `${value}%`;
    progressBar.style.width = `${value}%`;
  }

  if (testAgainBtn) testAgainBtn.addEventListener('click', () => {
    checkoutSuccess.classList.add('hidden');
    checkoutIdle.classList.remove('hidden');
  });

  if (goDashboardBtn) goDashboardBtn.addEventListener('click', () => {
    checkoutSuccess.classList.add('hidden');
    checkoutIdle.classList.remove('hidden');
    switchTab('dashboard');
  });
</script>
